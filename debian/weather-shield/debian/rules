#!/usr/bin/make -f
%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	install -d debian/weather-shield/etc/weather-shield
	install -m 644 config.json debian/weather-shield/etc/weather-shield/
	install -d debian/weather-shield/lib/systemd/system
	install -m 644 debian/weather-shield.service debian/weather-shield/lib/systemd/system/

override_dh_python3:
	dh_python3 --shebang=/usr/bin/python3
